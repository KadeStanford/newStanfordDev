# Example environment variables for production
# Option A: Mailgun (recommended for managed hosting)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=sandboxxxxxxx.mailgun.org
# MAILGUN_BASE_URL=https://api.mailgun.net
# MAILGUN_FROM=verified-sender@yourdomain.com
# CONTACT_RECEIVER=stanforddevcontact@gmail.com
# DEBUG_EMAIL=false

# Option B: SMTP fallback (if you prefer SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-smtp-password-or-app-password
# CONTACT_RECEIVER=stanforddevcontact@gmail.com
# DEBUG_EMAIL=false

# Option C: Mailgun (API-based)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=sandboxxxxxxx.mailgun.org
# MAILGUN_BASE_URL=https://api.mailgun.net
# MAILGUN_FROM=verified-sender@yourdomain.com

# GA4: Admin → Analytics tab → marketing site (numeric Property ID, not G- measurement ID)
# SITE_GA4_PROPERTY_ID=123456789
# Some hosts only expose NEXT_PUBLIC_* at build time — either works:
# NEXT_PUBLIC_SITE_GA4_PROPERTY_ID=123456789
# GA_SA_KEY_BASE64=... (or GA_SA_KEY / FIREBASE_SERVICE_ACCOUNT) — same service account as /api/ga/fetch-report
#
# Optional: use Amplify NEXT_PUBLIC_FIREBASE_* only when every value matches Console exactly:
# NEXT_PUBLIC_FIREBASE_USE_ENV=true
